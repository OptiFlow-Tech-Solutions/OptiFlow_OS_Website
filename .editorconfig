root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.{html,css}]
indent_style = space
indent_size = 2

[*.{js,mjs,json,yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[package.json]
indent_style = space
indent_size = 2
