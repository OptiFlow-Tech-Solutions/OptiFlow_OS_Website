# OptiFlow OS Website — Environment Configuration

# Runtime mode
NODE_ENV=production

# Server port (nginx default: 80)
PORT=80

# API backend URL (future: connect to backend services)
API_BASE_URL=http://localhost:3001

# Public site URL
SITE_URL=https://optiflow.in

# Admin credentials (for Cloudflare Workers API)
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Email (Resend API)
RESEND_API_KEY=
