# OptiFlow OS Website — Environment Configuration
#
# Port strategy:
#   Production (Docker / Coolify / Nixpacks): PORT=80  (nginx, no reverse proxy needed)
#   Development (local): PORT=3000  (use `npm run dev`, not `npm start`)
#
# Runtime mode
NODE_ENV=production

# Server port — port 80 in production, 3000 for local dev only
PORT=80

# Public site URL
SITE_URL=https://optiflow.in

# Domain for Coolify/Traefik routing
DOMAIN=optiflow.in

# API backend URL (future: connect to backend services)
API_BASE_URL=http://localhost:3001

# Admin credentials (for Cloudflare Workers API)
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Email (Resend API)
RESEND_API_KEY=
