# OptiFlow OS Website — Environment Configuration
# ================================================
# Copy this file to .env and fill in values for your deployment.
# .env is gitignored — never commit real secrets.
#
# ── Port & Domain ──
# Port strategy:
#   Production (Docker / Coolify / Nixpacks): PORT=80  (nginx, no reverse proxy needed)
#   Development (local): PORT=3000  (use `npm run dev`, not `npm start`)
NODE_ENV=production
PORT=80

# Public site URL (used in sitemap, OG tags, canonical URLs at build time)
SITE_URL=https://os.optiflow.co.in

# Domain for Coolify/Traefik routing. Also used in compose labels.
DOMAIN=os.optiflow.co.in

# ── Django Backend ──
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL Database ──
DB_NAME=optiflow_dev
DB_USER=optiflow
DB_PASSWORD=devpass
DB_HOST=db
DB_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated origins) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── API ──
# Public API base URL used by frontend to reach backend
API_BASE_URL=http://localhost:80

# ── Admin Credentials (Cloudflare Workers API) ──
# Required only if deploying with Cloudflare Workers for form handling.
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# ── Email (Resend API — Cloudflare Workers only) ──
# Required only for Workers-based form email notifications.
RESEND_API_KEY=

# ── Coolify-specific ──
# Set these if using Coolify with auto-deploy:
#   SERVICE_FQDN — auto-set by Coolify, but can override here
#   COOLIFY_FQDN — auto-set by Coolify
#   COOLIFY_URL  — auto-set by Coolify

# ── Traefik routing (set by Coolify, override if self-hosting Traefik) ──
# TRAEFIK_HOST=optiflow.in
